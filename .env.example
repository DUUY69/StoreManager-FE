# Copy file này thành .env và sửa giá trị theo môi trường của bạn
# Vite chỉ load biến có tiền tố VITE_

# Base URL Backend API (BE chạy port 5000, không có dấu / ở cuối)
VITE_API_BASE_URL=http://localhost:5000

# Bật gọi API thật (true). Tắt = dùng mock (false). Cần = true để cập nhật trạng thái đơn gửi lên BE
VITE_USE_API=true
